# Sericia Medusa v2 backend — env var reference (values live in Coolify)
# For local dev, copy this file to .env.local and replace placeholders.
# .env.local is git-ignored. Do NOT commit secrets.

# --- Database (use Coolify private-network hostname when running inside Coolify) ---
DATABASE_URL=postgres://medusa:<db-password>@h128il6uh7sxdkb5s3w0vuz7:5432/medusa
REDIS_URL=redis://default:<redis-password>@yau9i5yafa98tc8dm8ag5kmp:6379/0

# --- Medusa secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
JWT_SECRET=<32-byte hex>
COOKIE_SECRET=<32-byte hex>

# --- CORS ---
STORE_CORS=https://sericia.com,https://www.sericia.com
ADMIN_CORS=https://api.sericia.com,https://admin.sericia.com
AUTH_CORS=https://sericia.com,https://api.sericia.com,https://admin.sericia.com

# --- Runtime ---
NODE_ENV=production
PORT=9000

# --- Integrations ---
CROSSMINT_API_KEY=<prod sk from reference_api_keys.md>
CROSSMINT_WEBHOOK_SECRET=<set in Crossmint dashboard>
RESEND_API_KEY=<from reference_api_keys.md>
RAKUTEN_APP_ID=<from reference_api_keys.md>
RAKUTEN_ACCESS_KEY=<from reference_api_keys.md>
RAKUTEN_AFFILIATE_ID=<from reference_api_keys.md>
