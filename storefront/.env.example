NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.sericia.com
NEXT_PUBLIC_CROSSMINT_CLIENT_ID=
CROSSMINT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# PayloadCMS v3 (mounted at /cms/admin)
# ---------------------------------------------------------------------------
# 32+ char random string used to sign JWTs / encrypt sessions.
# Generate: openssl rand -base64 48
PAYLOAD_SECRET=generate-32-char-random

# Supabase Postgres connection used by Payload with schemaName=payload.
# DO NOT reuse the storefront's app.* schema — Payload owns its own schema.
# Example: postgres://USER:PASS@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?schema=payload
DATABASE_URL_PAYLOAD=

# First-run bootstrap (scripts/payload-bootstrap.ts).
# Creates an admin user on first boot IF no users exist. Safe to re-run.
PAYLOAD_ADMIN_EMAIL=admin@sericia.com
PAYLOAD_ADMIN_PASSWORD=change-me-on-first-login

# ---------------------------------------------------------------------------
# Supabase Storage (S3-compatible) for Payload Media uploads
# ---------------------------------------------------------------------------
# Supabase Project Settings > Storage > S3 Connection
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=sericia-media
SUPABASE_S3_REGION=ap-northeast-1
